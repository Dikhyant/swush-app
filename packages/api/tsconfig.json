{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "declaration": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./services/*"]
    }
  },
  "include": ["services/**/*", "services/*", "../../apps/web/src/services/types.ts", "../../apps/web/src/services/FrontendTransactionService.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
} 